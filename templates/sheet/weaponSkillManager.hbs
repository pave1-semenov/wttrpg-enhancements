{{#if tabs.weaponSkill}}
<section class="tab {{tabs.weaponSkill.cssClass}} scrollable" data-group="primary" data-tab="weaponSkill">
    <div class="weapon-skills-manager">
        <section class="weapon-skills-manager__dropzone-section">
            <div class="weapon-skills-dropzone" data-drop-zone>
                <div class="weapon-skills-dropzone__icon"><i class="fas fa-hand-sparkles"></i></div>
                <div class="weapon-skills-dropzone__title">Drop a weapon-skill template here</div>
                <div class="weapon-skills-dropzone__subtitle">A copied version will be created and attached to {{document.name}}</div>
            </div>
        </section>

        <section class="weapon-skills-manager__grid-section">
            <div class="weapon-skills-cards">
                {{#each attachedSkills}}
                <article class="weapon-skills-card">
                    <button type="button" class="weapon-skills-card__open" data-action="openSkill" data-skill-id="{{this.id}}" title="{{this.name}}">
                        <span class="weapon-skills-card__art">
                            <img class="weapon-skills-card__image" src="{{this.img}}" alt="{{this.name}}">
                        </span>
                        <span class="weapon-skills-card__name">{{this.name}}</span>
                    </button>
                    <button type="button" class="weapon-skills-card__remove" data-action="removeSkill" data-skill-id="{{this.id}}" aria-label="Remove {{this.name}}">
                        <i class="fas fa-times"></i>
                    </button>
                </article>
                {{/each}}

                <article class="weapon-skills-card weapon-skills-card--create">
                    <button type="button" class="weapon-skills-card__open" data-action="createSkill" aria-label="Create new skill">
                        <span class="weapon-skills-card__art weapon-skills-card__art--create">
                            <span class="weapon-skills-card__plus"><i class="fas fa-plus"></i></span>
                        </span>
                        <span class="weapon-skills-card__name">New Skill</span>
                    </button>
                </article>
            </div>
        </section>
    </div>
</section>
{{/if}}
